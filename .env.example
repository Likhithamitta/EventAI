# ─────────────────────────────────────────────────────────────
#  AI Event Planner — environment variables
#  Copy this file to .env and fill in your real values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Your IBM Cloud API key
# Get it from: https://cloud.ibm.com/iam/apikeys
IBM_WATSONX_API_KEY=your-ibm-cloud-api-key-here

# Your watsonx.ai project ID
# Get it from: https://dataplatform.cloud.ibm.com → Projects → your project → Manage → General
IBM_WATSONX_PROJECT_ID=your-watsonx-project-id-here

# Regional endpoint — change to match your IBM Cloud region:
#   Dallas   → https://us-south.ml.cloud.ibm.com
#   Frankfurt→ https://eu-de.ml.cloud.ibm.com
#   Tokyo    → https://jp-tok.ml.cloud.ibm.com
#   Sydney   → https://au-syd.ml.cloud.ibm.com  ← default
IBM_WATSONX_URL=https://au-syd.ml.cloud.ibm.com
